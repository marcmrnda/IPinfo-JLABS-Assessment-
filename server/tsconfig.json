{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "rootDir": "./api",         
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "types": ["node"],
    "sourceMap": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "declaration": true,
    "declarationMap": true
  },
  "include": [
    "api/**/*.ts",
    "api/routes/**/*.ts",
    "api/controllers/**/*.ts",
    "api/middlewares/**/*.ts",
    "api/lib/**/*.ts",
    "api/seedData.ts",
    "api/dummyData/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}